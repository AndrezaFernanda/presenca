# ─────────────────────────────────────────────
# PresençaCerta — Configuração de Ambiente
# ─────────────────────────────────────────────
# Copie este arquivo para .env e ajuste os valores

# ── Banco de Dados ──────────────────────────
# Escolha: "sqlite" ou "postgres"
DB_TYPE=sqlite

# SQLite: caminho do arquivo (relativo ao projeto)
SQLITE_PATH=presencacerta.db

# PostgreSQL: preencha apenas se DB_TYPE=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=presencacerta
POSTGRES_USER=postgres
POSTGRES_PASSWORD=senha_aqui

# ── Aplicação ───────────────────────────────
# URL pública da aplicação (usado para gerar QR Codes e links)
# No Streamlit Cloud: https://seu-app.streamlit.app
# Local: http://localhost:8501
APP_URL=http://localhost:8501

# Nome da empresa (exibido nos relatórios)
EMPRESA_NOME=Minha Empresa

# Logo (URL pública ou deixe em branco)
EMPRESA_LOGO=
