# .streamlit/secrets.toml
# ─────────────────────────────────────────────────────────────────
# Arquivo de segredos para o Streamlit Cloud.
# NÃO versione este arquivo (já está no .gitignore).
# No Streamlit Cloud, configure via Settings → Secrets.
# ─────────────────────────────────────────────────────────────────

# URL pública da aplicação (usada para gerar QR Codes)
APP_URL = "https://seu-app.streamlit.app"

# Nome da empresa
EMPRESA_NOME = "Minha Empresa"

# Tipo de banco: "sqlite" (padrão) ou "postgres"
DB_TYPE = "sqlite"

# Apenas para PostgreSQL:
# [postgres]
# host     = "seu-host.render.com"
# port     = 5432
# db       = "presencacerta"
# user     = "postgres"
# password = "sua-senha-secreta"
